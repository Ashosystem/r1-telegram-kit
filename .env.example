# Telegram API credentials — get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session string — generated by running: npm run setup
TELEGRAM_SESSION=

# Secret token the R1 creation uses to authenticate with this backend
R1_AUTH_TOKEN=change-me-to-something-random

# Port for the HTTP/WS server
PORT=3000

# (Optional) OpenAI API key for backend STT fallback via Whisper
# Only needed if Web Speech API doesn't work on the R1's WebView
OPENAI_API_KEY=
