# ─── Required ────────────────────────────────────────────────────────
# Get these from https://my.telegram.org → API Development Tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Optional ────────────────────────────────────────────────────────

# Pre-generated Telegram session string. Leave blank on first deploy;
# the app will print one to the logs after your first web login so you
# can paste it here for extra resilience against volume resets.
TELEGRAM_SESSION=

# Secret that protects the R1 app URL. If blank, one is auto-generated
# on first boot and stored under the data volume. You only need to set
# this if you want a fixed, memorable token.
R1_AUTH_TOKEN=

# OpenAI API key for Whisper STT fallback (used when the R1's native
# voice handler isn't available, e.g. desktop testing).
OPENAI_API_KEY=

# Port to listen on. Railway sets this automatically; leave blank locally
# to default to 3000.
PORT=
